{
	"$schema": "https://json.schemastore.org/claude-code-settings.json",
	"permissions": {
		"allow": [
			"Bash(npm install)",
			"Bash(npm ci)",
			"Bash(npm run dev:*)",
			"Bash(npm run build:*)",
			"Bash(npm run preview:*)",
			"Bash(npm run check:*)",
			"Bash(npm run lint:*)",
			"Bash(npm run format:*)",
			"Bash(npm test:*)",
			"Bash(npm run test:*)",
			"Bash(npx vitest:*)",
			"Bash(git add:*)",
			"Bash(git status:*)",
			"Bash(git diff:*)",
			"Bash(git log:*)",
			"Read(*)",
			"Edit",
			"Skill(*)"
		],
		"ask": ["Bash(git commit:*)", "Bash(git push:*)"],
		"deny": [],
		"defaultMode": "default"
	}
}
